---
import CarouselReact from './CarouselReact.jsx';

interface Props {
  id: string;
  autoplay?: number;
  items?: string[];
}

const { id, autoplay, items = ['1', '2', '3', '4', '5', '6'] } = Astro.props;
const normalizedId = id.toLowerCase().replace(/[^a-z0-9_-]/g, '-');
const carouselAnchor = `--css-carousel-${normalizedId}`;
---

<div
  id={id}
  class:list={[
    'carousel relative flex overflow-x-auto scroll-smooth snap-x snap-mandatory py-4',
    '-ml-2 md:-ml-4',
  ]}
  style={`--carousel-anchor: ${carouselAnchor};`}
  data-carousel
  data-autoplay={autoplay}
>
  {items.map((item) => (
    <div
      class:list={[
        'carousel-item',
        'min-w-0 shrink-0 grow-0 basis-full pl-2 md:pl-4',
        'md:basis-1/2 lg:basis-1/3',
        'snap-center [scroll-snap-stop:always]',
      ]}
    >
      <div class="min-h-[200px] md:min-h-[300px] bg-slate-100 rounded-xl flex items-center justify-center text-6xl font-bold text-slate-400 hover:bg-slate-200 transition-colors">
        {item}
      </div>
    </div>
  ))}
</div>

<div class="react-carousel-fallback">
  <CarouselReact
    items={items}
    autoplay={autoplay}
    client:unless-supports="selector(::scroll-button(left))"
  />
</div>

<style>
  /* CSS-only Scroll Buttons (Chrome 135+) */
  @supports selector(::scroll-button(left)) {
    .carousel {
      scroll-marker-group: after;
      scrollbar-width: none;
      -ms-overflow-style: none;
      anchor-name: var(--carousel-anchor);
    }

    .carousel::-webkit-scrollbar {
      display: none;
    }

    .carousel::scroll-button(left),
    .carousel::scroll-button(right) {
      content: '←' / 'Previous slide';
      position: fixed;
      position-anchor: var(--carousel-anchor);
      position-area: center left;
      width: 2rem;
      height: 2rem;
      border-radius: 9999px;
      background-color: var(--background);
      box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
      border: 1px solid var(--border);
      display: grid;
      place-items: center;
      font-size: 1rem;
      font-weight: 500;
      color: var(--foreground);
      cursor: pointer;
      transition: background-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease,
        opacity 0.15s ease;
      z-index: 10;
    }

    .carousel::scroll-button(left) {
      margin-left: 0.75rem;
    }

    .carousel::scroll-button(right) {
      content: '→' / 'Next slide';
      position-area: center right;
      margin-right: 0.75rem;
    }

    .carousel::scroll-button(*):hover {
      background-color: var(--accent);
      color: var(--accent-foreground);
    }

    .carousel::scroll-button(*):disabled {
      opacity: 0.5;
      pointer-events: none;
    }

    .carousel-item::scroll-marker {
      content: '';
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 9999px;
      background-color: color-mix(in oklab, var(--muted-foreground) 30%, transparent);
      transition: background-color 0.15s ease, transform 0.15s ease;
      cursor: pointer;
    }

    .carousel-item::scroll-marker:hover {
      background-color: color-mix(in oklab, var(--muted-foreground) 50%, transparent);
    }

    .carousel-item::scroll-marker:target-current {
      background-color: var(--primary);
      transform: scale(1.25);
    }

    .carousel::scroll-marker-group {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    /* Hide React fallback when CSS works */
    .react-carousel-fallback {
      display: none !important;
    }
  }

  /* Show React fallback when CSS doesn't work */
  @supports not selector(::scroll-button(left)) {
    .carousel {
      display: none !important;
    }

    .react-carousel-fallback {
      display: block;
    }
  }
</style>
